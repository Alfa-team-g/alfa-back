# Configuração do agendamento (cron)
# Padrão: a cada 6 horas
CRON_SCHEDULE="0 */6 * * *"

# Firebase Admin (Cloud Firestore)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINE_1\nYOUR_KEY_LINE_2\n-----END PRIVATE KEY-----\n"

# Telegram bot alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Livelo partner catalog URL for scraping partner image/link
LIVELO_PARTNERS_URL=https://www.livelo.com.br/ganhe-pontos-em-compras-online

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/YOUR_PHONE_NUMBER_ID/messages
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE=5511999999999

# Webhook (Discord/Slack/Outros)
WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Email (SendGrid, Mailgun, etc.)
EMAIL_API_URL=https://api.sendgrid.com/v3/mail/send
EMAIL_API_KEY=your_email_api_key
EMAIL_TO=seu@email.com
